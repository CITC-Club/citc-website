# PostgreSQL (Drizzle)
DATABASE_URL=postgresql://user:password@host:5432/database

# Supabase (admin auth + media storage; bucket is created automatically on first upload)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# "Publishable" key from API Keys → Publishable and secret (or legacy anon)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
# API Keys → Legacy anon, service_role → copy the service_role secret (not the new "secret" key)
SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
# SUPABASE_STORAGE_BUCKET=media

# Optional: canonical URL for SEO/Open Graph (defaults to https://citc.ncit.edu.np)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Container Registry (GHCR) Configuration (for Docker deployment)
GHCR_USER=your-github-username
GHCR_TOKEN=your-github-personal-access-token-with-read-packages

# Let's Encrypt Email (for SSL/TLS certificate updates)
LETSENCRYPT_EMAIL=citc@ncit.edu.np
